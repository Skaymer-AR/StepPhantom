<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Ver todas las apps instaladas en el selector (herramienta sideloaded). -->
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="QueryAllPackagesPermission" />

    <!-- Para apps de PRUEBA propias que leen step counter. -->
    <uses-permission android:name="android.permission.ACTIVITY_RECOGNITION" />
    <uses-permission android:name="android.permission.HIGH_SAMPLING_RATE_SENSORS" />

    <!-- Escritura oficial de prueba en Health Connect (Android 14+). Apagada por defecto. -->
    <uses-permission android:name="android.permission.health.READ_STEPS" />
    <uses-permission android:name="android.permission.health.WRITE_STEPS" />

    <application
        android:allowBackup="true"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.StepPhantom">

        <!-- ===== Metadatos que LSPosed/Vector leen (API clásica 82) ===== -->
        <meta-data android:name="xposedmodule" android:value="true" />
        <meta-data android:name="xposeddescription" android:value="@string/xposed_desc" />
        <meta-data android:name="xposedminversion" android:value="82" />

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
            Rationale de permisos de Health Connect. Requerido por HC para explicar
            el uso. Plumbing dependiente de versión: si tu versión de connect-client
            pide otra acción/categoría, ajustá acá.
        -->
        <activity-alias
            android:name=".HcPermissionsRationale"
            android:exported="true"
            android:targetActivity=".MainActivity"
            android:permission="android.permission.START_VIEW_PERMISSION_USAGE">
            <intent-filter>
                <action android:name="android.intent.action.VIEW_PERMISSION_USAGE" />
                <category android:name="android.intent.category.HEALTH_PERMISSIONS" />
            </intent-filter>
            <intent-filter>
                <action android:name="androidx.health.ACTION_SHOW_PERMISSIONS_RATIONALE" />
            </intent-filter>
        </activity-alias>

        <!-- Puente de CONFIG (solo lectura, UID validado en código). -->
        <provider
            android:name=".config.ConfigProvider"
            android:authorities="com.stepphantom.config"
            android:exported="true"
            android:grantUriPermissions="true" />

        <!-- Canal INVERSO de diagnóstico (escritura sólo desde targets autorizados). -->
        <provider
            android:name=".config.DiagnosticsProvider"
            android:authorities="com.stepphantom.diagnostics"
            android:exported="true"
            android:grantUriPermissions="true" />

    </application>
</manifest>
