<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Necesario para que una app de PRUEBA propia pueda leer el step counter. -->
    <uses-permission android:name="android.permission.ACTIVITY_RECOGNITION" />
    <!-- Opcional: muestreo alto de sensores (>200 Hz) en apps de prueba. -->
    <uses-permission android:name="android.permission.HIGH_SAMPLING_RATE_SENSORS" />

    <application
        android:allowBackup="true"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.StepPhantom">

        <!-- ===== Metadatos que LSPosed/Vector leen para reconocer el módulo ===== -->
        <meta-data
            android:name="xposedmodule"
            android:value="true" />
        <meta-data
            android:name="xposeddescription"
            android:value="@string/xposed_desc" />
        <!-- 82 = API clásica de Xposed. Compatible con LSPosed y Vector. -->
        <meta-data
            android:name="xposedminversion"
            android:value="82" />

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
            Puente de configuración hacia el proceso hookeado.
            exported=true porque el consumidor es la app objetivo (otro UID) que
            no tiene ningún permiso custom nuestro. Sólo expone config de pasos.
            Ver ConfigProvider.kt para endurecerlo con verificación de UID.
        -->
        <provider
            android:name=".config.ConfigProvider"
            android:authorities="com.stepphantom.config"
            android:exported="true"
            android:grantUriPermissions="true" />

    </application>
</manifest>
